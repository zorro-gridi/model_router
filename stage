#!/usr/bin/env python3
"""
stage — 阶段管理 CLI
=====================
用法：
  stage              # 查看当前阶段
  stage brainstorm   # 手动设置阶段
  stage reset        # 重置为 default
  stage proxy        # 启动代理服务器
  stage status       # 查询代理健康状态
  stage log          # 实时查看路由日志

操作类型子命令（第二维度，2026-06-13 引入）：
  stage op <name>    # 手动设置 op（覆盖 stage 路由）
  stage op reset     # 清除 op 信号（退回 stage 路由）
  stage op list      # 列出所有有效 op 名称

所有阶段：brainstorm | decide | design | plan | implement | audit | default
所有 op：  write | read | search | refactor

阶段文件位置：
  分 session 阶段文件：<project_root>/.claude/stage_<session_id>
  分 session op 文件： <project_root>/.claude/op_<session_id>（op_<sid> 与 stage_<sid> 同目录）
  active_session 指针：~/.claude/hooks/model_router/active_session → 完整路径
  全局后备：          ~/.claude/hooks/model_router/current_stage（仅 stage，op 无全局后备）
"""

import http.client
import json
import os
import re
import subprocess
import sys
from pathlib import Path

# ── 分 session 阶段管理 ──
HOME_CLAUDE         = Path.home() / ".claude"
HOOK_DIR            = HOME_CLAUDE / "hooks" / "model_router"
ACTIVE_SESSION_FILE = HOOK_DIR / "active_session"
GLOBAL_STAGE_FILE   = HOOK_DIR / "current_stage"
LOG_FILE            = HOME_CLAUDE / "stage-router.log"
# 注：stage CLI 装在 ~/.local/bin/，但 proxy.py 和 .env 在 ~/.claude/hooks/model_router/。
# 不能用 Path(__file__).parent（取到的是 ~/.local/bin/，proxy.py 不在那）。
PROXY_SCRIPT        = HOOK_DIR / "proxy.py"
ENV_FILE            = HOOK_DIR / ".env"
PROXY_PORT          = 7878

VALID_STAGES = {"brainstorm", "decide", "design", "plan", "implement", "audit", "default"}
# op 有效值：与 stage_config.OPERATION_CONFIG 同源
sys.path.insert(0, str(HOOK_DIR))
from stage_config import STAGE_CONFIG, OPERATION_CONFIG  # noqa: E402
VALID_STAGES = set(STAGE_CONFIG.keys())
VALID_OPS    = set(OPERATION_CONFIG.keys())

# 与 proxy.py 同步的极简 .env 解析（不依赖 python-dotenv）
_DOTENV_LINE = re.compile(r"^\s*([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*?)\s*$")


def _load_dotenv(env_path: Path) -> int:
    """从 .env 加载到 os.environ（已有变量不被覆盖）。返回加载数量。"""
    if not env_path.exists():
        return 0
    loaded = 0
    try:
        for raw in env_path.read_text(encoding="utf-8").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            m = _DOTENV_LINE.match(line)
            if not m:
                continue
            key, value = m.group(1), m.group(2)
            if (value.startswith('"') and value.endswith('"')) or \
               (value.startswith("'") and value.endswith("'")):
                value = value[1:-1]
            if key not in os.environ:
                os.environ[key] = value
                loaded += 1
    except OSError as e:
        print(f"⚠️  读取 {env_path} 失败: {e}", file=sys.stderr)
    return loaded


COLORS = {
    "brainstorm": "\033[36m",   # cyan
    "decide":     "\033[35m",   # magenta
    "design":     "\033[34m",   # blue
    "plan":       "\033[33m",   # yellow
    "implement":  "\033[32m",   # green
    "audit":      "\033[31m",   # red
    "default":    "\033[37m",   # white
    "reset":      "\033[0m",
}

# 从统一配置文件导入（需先将 HOOK_DIR 加入 sys.path）
sys.path.insert(0, str(HOOK_DIR))
from stage_config import STAGE_DESC, OPERATION_DESC


# ── 项目根目录查找（参照 compact/utils.py，但无 stdin——从 Path.cwd() 出发）──

def _find_project_root(start: Path, session_id: str | None = None) -> Path:
    """Walk up from ``start`` looking for a project boundary marker.

    Anchor strategy:
      1. If session_id is known, walk up looking for stage_<sid> or
         session_state_<sid>.json under .claude/ — its parent IS the project root.
      2. Walk up looking for .claude/ (skip global ~/.claude unless started there).
      3. Walk up looking for .git/ as fallback.
      4. Fall back to ~/.claude.
    """
    p = start

    if session_id:
        anchor_p = start
        for _ in range(20):
            claude_dir = anchor_p / ".claude"
            if (claude_dir / f"stage_{session_id}").exists() or \
               (claude_dir / f"session_state_{session_id}.json").exists():
                return anchor_p
            parent = anchor_p.parent
            if parent == anchor_p:
                break
            anchor_p = parent

    git_root = None
    for _ in range(20):
        cand = p / ".claude"
        if cand.is_dir():
            if cand != HOME_CLAUDE or str(start).startswith(str(HOME_CLAUDE) + os.sep):
                return p
        if git_root is None and (p / ".git").exists():
            git_root = p
        parent = p.parent
        if parent == p:
            break
        p = parent

    if git_root is not None:
        return git_root
    return HOME_CLAUDE if HOME_CLAUDE.is_dir() else start


def _get_active_session_id() -> str | None:
    """从 active_session 指针提取 session_id。

    active_session 存储的是完整路径如 /path/to/.claude/stage_<sid>，
    从中提取 <sid> 部分。若指针是老格式（仅 session_id），直接返回。
    """
    try:
        raw = ACTIVE_SESSION_FILE.read_text().strip()
        if not raw:
            return None
    except FileNotFoundError:
        return None

    # 新格式：完整路径 → 提取 stage_<sid> 文件名
    # 也可兼容老格式：纯 session_id
    if "/" in str(raw) or raw.endswith(".json"):
        # 完整路径 → 提取文件名
        name = Path(raw).name
        if name.startswith("stage_"):
            return name[len("stage_"):]
        # 也可能是 session_state_<sid>.json（极端情况）
        if name.startswith("session_state_") and name.endswith(".json"):
            return name[len("session_state_"):-len(".json")]
        return None
    # 老格式：纯 session_id
    return raw


def _get_active_stage_path() -> Path | None:
    """读取 active_session 指针中存储的完整路径。"""
    try:
        raw = ACTIVE_SESSION_FILE.read_text().strip()
        if not raw:
            return None
    except FileNotFoundError:
        return None

    # 新格式：完整绝对路径
    if raw.startswith("/"):
        return Path(raw)
    # 老格式：纯 session_id → 用 cwd 解析
    session_id = raw
    project_root = _find_project_root(Path.cwd(), session_id)
    claude_dir = project_root / ".claude"
    if not claude_dir.is_dir():
        claude_dir.mkdir(parents=True, exist_ok=True)
    return claude_dir / f"stage_{session_id}"


def read_stage() -> str:
    """
    读取当前阶段，优先级：
      1. active_session 指针 → 读取其存储的完整路径文件
      2. 全局后备文件 → current_stage
      3. default
    """
    # 1. active_session → 完整路径
    stage_path = _get_active_stage_path()
    if stage_path:
        try:
            content = stage_path.read_text().strip()
            if content:
                return content
        except FileNotFoundError:
            pass

    # 2. 全局后备
    try:
        content = GLOBAL_STAGE_FILE.read_text().strip()
        if content:
            return content
    except FileNotFoundError:
        pass

    return "default"


def write_stage(stage: str) -> None:
    """
    写入阶段。
    若存在 active_session 指针 → 写入 <project_root>/.claude/stage_<sid>；
    否则写入全局后备文件 current_stage。
    """
    session_id = _get_active_session_id()
    if session_id:
        project_root = _find_project_root(Path.cwd(), session_id)
        claude_dir = project_root / ".claude"
        claude_dir.mkdir(parents=True, exist_ok=True)
        stage_path = claude_dir / f"stage_{session_id}"
        stage_path.write_text(stage)
        # 同步更新 active_session 指针（完整路径）
        HOOK_DIR.mkdir(parents=True, exist_ok=True)
        ACTIVE_SESSION_FILE.write_text(str(stage_path))
    else:
        GLOBAL_STAGE_FILE.parent.mkdir(parents=True, exist_ok=True)
        GLOBAL_STAGE_FILE.write_text(stage)


def _op_file_path(stage_path: Path) -> Path:
    """从 stage_<sid> 路径派生 op_<sid> 路径（同目录、仅前缀替换）。"""
    return stage_path.with_name(stage_path.name.replace("stage_", "op_", 1))


def read_operation() -> str | None:
    """
    读取当前 op（与 read_stage() 平行独立的第二维度）。
    返回 None 表示"无 op 信号"（proxy 走 stage 路由）。
    """
    stage_path = _get_active_stage_path()
    if stage_path:
        try:
            content = _op_file_path(stage_path).read_text().strip()
            if content:
                return content
        except FileNotFoundError:
            pass
    return None


def write_operation(op: str) -> bool:
    """
    写入 op 到 op_<sid>（与 stage_<sid> 同目录）。
    无 active_session 时不写入——op 不设全局后备。
    """
    stage_path = _get_active_stage_path()
    if not stage_path:
        return False
    op_path = _op_file_path(stage_path)
    op_path.parent.mkdir(parents=True, exist_ok=True)
    op_path.write_text(op)
    return True


def clear_operation() -> bool:
    """清除 op 信号（删除 op_<sid> 文件），proxy 退回 stage 路由。"""
    stage_path = _get_active_stage_path()
    if not stage_path:
        return False
    op_path = _op_file_path(stage_path)
    try:
        op_path.unlink()
        return True
    except FileNotFoundError:
        return False


def show_current():
    stage = read_stage()
    color = COLORS.get(stage, COLORS["reset"])
    desc  = STAGE_DESC.get(stage, "")
    print(f"当前阶段: {color}{stage}\033[0m")
    print(f"  {desc}")
    op = read_operation()
    if op:
        op_desc = OPERATION_DESC.get(op, "")
        print(f"当前 op:   \033[1;33m{op}\033[0m (覆盖 stage 路由)")
        print(f"  {op_desc}")
    else:
        print(f"当前 op:   \033[90mnone\033[0m (走 stage 路由)")
    print(f"\n代理地址: http://127.0.0.1:{PROXY_PORT}")
    print(f"设置方式: export ANTHROPIC_BASE_URL=http://127.0.0.1:{PROXY_PORT}")


def set_stage(stage: str):
    if stage not in VALID_STAGES:
        print(f"❌ 未知阶段: {stage}")
        print(f"   有效值: {' | '.join(sorted(VALID_STAGES))}")
        sys.exit(1)
    old = read_stage()
    write_stage(stage)
    color = COLORS.get(stage, COLORS["reset"])
    print(f"阶段切换: {old} → {color}{stage}\033[0m")
    print(f"  {STAGE_DESC.get(stage, '')}")


def set_op(op: str):
    if op not in VALID_OPS:
        print(f"❌ 未知 op: {op}")
        print(f"   有效值: {' | '.join(sorted(VALID_OPS))}")
        sys.exit(1)
    if not write_operation(op):
        print(f"❌ 无法写入 op：无活跃 session（active_session 指针不存在）")
        print(f"   先发起一次 Claude Code 会话触发 UserPromptSubmit hook 创建 session")
        sys.exit(1)
    old = read_operation() or "none"
    print(f"op 切换:   {old} → \033[1;33m{op}\033[0m (覆盖 stage 路由)")
    print(f"  {OPERATION_DESC.get(op, '')}")


def reset_op():
    if not clear_operation():
        print("ℹ️  当前没有 op 信号（文件不存在或无 session）")
        return
    print("✅ op 已清除，下一次请求将退回 stage 路由")


def list_ops():
    print("可用 op 名称（第二维度路由信号，op 覆盖 stage）：")
    for op in sorted(VALID_OPS):
        print(f"  {OPERATION_DESC.get(op, op)}")


def start_proxy():
    print(f"启动 Stage Router 代理（端口 {PROXY_PORT}）...")
    print(f"设置环境变量: export ANTHROPIC_BASE_URL=http://127.0.0.1:{PROXY_PORT}")
    print("按 Ctrl+C 停止\n")
    subprocess.run([sys.executable, str(PROXY_SCRIPT), "--port", str(PROXY_PORT)])


def proxy_status():
    try:
        conn = http.client.HTTPConnection("127.0.0.1", PROXY_PORT, timeout=2)
        conn.request("GET", "/health")
        resp = conn.getresponse()
        data = json.loads(resp.read())
        stage = data.get("stage", "unknown")
        model = data.get("model", "unknown")
        op = data.get("op")
        color = COLORS.get(stage, COLORS["reset"])
        print(f"✅ Stage Router 运行中")
        if op:
            print(f"   阶段: {color}{stage}\033[0m")
            print(f"   op:   \033[1;33m{op}\033[0m (覆盖 stage)")
            print(f"   模型: {model}")
        else:
            print(f"   阶段: {color}{stage}\033[0m → {model}")
    except Exception:
        print(f"❌ Stage Router 未运行（端口 {PROXY_PORT}）")
        print(f"   启动命令: stage proxy")


def tail_log():
    subprocess.run(["tail", "-f", str(LOG_FILE)])


def print_help():
    print(__doc__)
    print("当前阶段:", read_stage())


def main():
    # 先加载本目录 .env（已有 shell env 不被覆盖）
    n_loaded = _load_dotenv(ENV_FILE)
    if n_loaded:
        print(f"ℹ️  从 {ENV_FILE} 加载了 {n_loaded} 个环境变量", file=sys.stderr)

    args = sys.argv[1:]

    if not args:
        show_current()
    elif args[0] == "proxy":
        start_proxy()
    elif args[0] == "status":
        proxy_status()
    elif args[0] == "log":
        tail_log()
    elif args[0] == "reset":
        set_stage("default")
    elif args[0] == "op":
        # stage op <name> | stage op reset | stage op list
        if len(args) < 2:
            print("用法: stage op <write|read|search|refactor>")
            print("      stage op reset")
            print("      stage op list")
            sys.exit(1)
        sub = args[1]
        if sub == "reset":
            reset_op()
        elif sub == "list":
            list_ops()
        elif sub in VALID_OPS:
            set_op(sub)
        else:
            print(f"❌ 未知 op 子命令: {sub}")
            print(f"   有效值: {' | '.join(sorted(VALID_OPS))} | reset | list")
            sys.exit(1)
    elif args[0] in VALID_STAGES:
        set_stage(args[0])
    elif args[0] in ("-h", "--help", "help"):
        print_help()
    else:
        print(f"未知命令: {args[0]}")
        print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
