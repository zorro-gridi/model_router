def _find_project_root(start: Path, session_id: str | None = None) -> Path:
    """Walk up from ``start`` looking for a project boundary marker.

    Anchor strategy:
      1. If session_id is known, walk up looking for stage_<sid> or
         session_state_<sid>.json under .claude/ — its parent IS the project root.
      2. Walk up looking for .claude/ (skip global ~/.claude unless started there).
      3. Walk up looking for .git/ as fallback.
      4. Fall back to ~/.claude.
    """
    p = start

    if session_id:
        anchor_p = start
        for _ in range(20):
            claude_dir = anchor_p / ".claude"
            if (claude_dir / f"stage_{session_id}").exists() or \
               (claude_dir / f"session_state_{session_id}.json").exists():
                return anchor_p
            parent = anchor_p.parent
            if parent == anchor_p:
                break
            anchor_p = parent

    git_root = None
    for _ in range(20):
        cand = p / ".claude"
        if cand.is_dir():
            if cand != HOME_CLAUDE or str(start).startswith(str(HOME_CLAUDE) + os.sep):
                return p
        if git_root is None and (p / ".git").exists():
            git_root = p
        parent = p.parent
        if parent == p:
            break
        p = parent

    if git_root is not None:
        return git_root
    return HOME_CLAUDE if HOME_CLAUDE.is_dir() else start


def _get_active_session_id() -> str | None:
    """从 active_session 指针提取 session_id。

    active_session 存储的是完整路径如 /path/to/.claude/stage_<sid>，
    从中提取 <sid> 部分。若指针是老格式（仅 session_id），直接返回。
    """
    try:
        raw = ACTIVE_SESSION_FILE.read_text().strip()
        if not raw:
            return None
    except FileNotFoundError:
        return None

    # 新格式：完整路径 → 提取 stage_<sid> 文件名
    # 也可兼容老格式：纯 session_id
    if "/" in str(raw) or raw.endswith(".json"):
        # 完整路径 → 提取文件名
        name = Path(raw).name
        if name.startswith("stage_"):
            return name[len("stage_"):]
        # 也可能是 session_state_<sid>.json（极端情况）
        if name.startswith("session_state_") and name.endswith(".json"):
            return name[len("session_state_"):-len(".json")]
        return None
    # 老格式：纯 session_id
    return raw


def _get_active_stage_path() -> Path | None:
    """读取 active_session 指针中存储的完整路径。"""
    try:
        raw = ACTIVE_SESSION_FILE.read_text().strip()
        if not raw:
            return None
    except FileNotFoundError:
        return None

    # 新格式：完整绝对路径
    if raw.startswith("/"):
        return Path(raw)
    # 老格式：纯 session_id → 用 cwd 解析
    session_id = raw
    project_root = _find_project_root(Path.cwd(), session_id)
    claude_dir = project_root / ".claude"
    if not claude_dir.is_dir():
        claude_dir.mkdir(parents=True, exist_ok=True)
    return claude_dir / f"stage_{session_id}"


def read_stage() -> str:
    """
    读取当前阶段：
      1. active_session 指针 → 读取其存储的完整路径文件
      2. default（无全局后备，每个 session 独立维护 stage_<sid>）
    """
    # 1. active_session → 完整路径
    stage_path = _get_active_stage_path()
    if stage_path:
        try:
            content = stage_path.read_text().strip()
            if content:
                return content
        except FileNotFoundError:
            pass

    return "default"


def write_stage(stage: str) -> None:
    """
    写入阶段。
    若存在 active_session 指针 → 写入 <project_root>/.claude/stage_<sid>；
    否则写入全局后备文件 current_stage。
    """
    session_id = _get_active_session_id()
    if session_id:
        project_root = _find_project_root(Path.cwd(), session_id)
        claude_dir = project_root / ".claude"
        claude_dir.mkdir(parents=True, exist_ok=True)
        stage_path = claude_dir / f"stage_{session_id}"
        stage_path.write_text(stage)
        # 同步更新 active_session 指针（完整路径）
        HOOK_DIR.mkdir(parents=True, exist_ok=True)
        ACTIVE_SESSION_FILE.write_text(str(stage_path))
    else:
        GLOBAL_STAGE_FILE.parent.mkdir(parents=True, exist_ok=True)
        GLOBAL_STAGE_FILE.write_text(stage)


# ── Pattern 读 / 写 / 清（Shadow Mode，2026-06-14 引入）──

def _pattern_file_path(stage_path: Path) -> Path:
    """从 stage_<sid> 派生 pattern_<sid> 路径（同目录、仅前缀替换）。"""
    return stage_path.with_name(stage_path.name.replace("stage_", "pattern_", 1))


def read_pattern() -> dict | None:
    """读取当前 session 的 pattern 标注（JSON 格式）。
    返回 None 或 `{"prediction": str, "confidence": float, "ts": str}`。
    """
    stage_path = _get_active_stage_path()
    if not stage_path:
        return None
    pattern_file = _pattern_file_path(stage_path)
    try:
        content = pattern_file.read_text().strip()
        if not content:
            return None
        return json.loads(content)
    except (FileNotFoundError, json.JSONDecodeError):
        return None


def write_pattern(prediction: str, confidence: float = 1.0) -> bool:
    """写入 pattern 标注到 pattern_<sid>（JSON 格式）。"""
    stage_path = _get_active_stage_path()
    if not stage_path:
        return False
    pattern_file = _pattern_file_path(stage_path)
    pattern_file.parent.mkdir(parents=True, exist_ok=True)
    payload = {
        "prediction": prediction,
        "confidence": round(float(confidence), 2),
        "ts":         datetime.now(timezone.utc).isoformat(timespec="seconds"),
    }
    pattern_file.write_text(json.dumps(payload, ensure_ascii=False))
    return True


def clear_pattern() -> bool:
    """清除 pattern_<sid> 标注。"""
    stage_path = _get_active_stage_path()
    if not stage_path:
        return False
    try:
        _pattern_file_path(stage_path).unlink()
        return True
    except FileNotFoundError:
        return False


