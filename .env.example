# Stage-Aware Model Router 环境变量模板
# ──────────────────────────────────────────
# 用法：
#   cp .env.example .env
#   编辑 .env 填入真实 key
#
# .env 已被 ~/.claude/.gitignore 屏蔽（hooks/**/.env），不会进 git。
# proxy.py 和 stage CLI 启动时会自动从本目录加载 .env 到 os.environ。

# ── MiniMax（Anthropic SDK）──────────────────────────────
# 来源：https://api.minimaxi.com/anthropic
# 用途：decide / design / audit 阶段的深度推理
MINIMAX_API_KEY=

# ── DeepSeek（Anthropic SDK）─────────────────────────────
# 来源：https://api.deepseek.com/anthropic
# 用途：brainstorm（v4-flash）+ plan/implement/default（v4-pro）
DEEPSEEK_API_KEY=